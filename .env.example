MODEL_URL=http://your-llm-server:port/
MODEL_NAME=Qwen3.6
ENABLE_THINKING=false
MAX_AGENTS=4

# Optional: vision LLM for scanned PDFs that survive neither pdfplumber nor ocrmypdf
# VISION_MODEL_URL=http://localhost:11434
# VISION_MODEL_NAME=qwen2.5vl:3b
# VISION_REQUEST_TIMEOUT=300       # increase for slow edge hardware (Jetson Orin)
# VISION_MAX_PAGES=5               # max pages per document sent to vision model
# VISION_NUM_CTX=4096              # context window; 4096 works for 72 DPI A4 pages